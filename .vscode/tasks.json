{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install",
      "detail": "Install tools and verify environment for all build=true targets",
      "type": "shell",
      "command": "make install",
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "install: target",
      "detail": "Install tools for a specific target",
      "type": "shell",
      "command": "make install TARGET=${input:target}",
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "build",
      "detail": "Build release artifacts for all build=true targets",
      "type": "shell",
      "command": "make build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$dart"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "build: target",
      "detail": "Build a specific target",
      "type": "shell",
      "command": "make build TARGET=${input:target}",
      "group": "build",
      "problemMatcher": ["$dart"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "run",
      "detail": "Run app (auto-selects target if only one build=true)",
      "type": "shell",
      "command": "make run TARGET=${input:target}",
      "group": "test",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "debug",
      "detail": "Run app with hot reload (auto-selects if only one debug=true)",
      "type": "shell",
      "command": "make debug TARGET=${input:target}",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "clean",
      "detail": "Remove all build artifacts",
      "type": "shell",
      "command": "make clean",
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ],
  "inputs": [
    {
      "id": "target",
      "type": "pickString",
      "description": "Target",
      "options": ["ios", "android", "macos", "web"],
      "default": "ios"
    }
  ]
}
